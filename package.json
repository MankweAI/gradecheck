{
  "name": "gradecheck",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run pipeline:publishability && next build",
    "db:migrate-supabase": "tsx ./scripts/migrate-local-postgres-to-supabase.ts",
    "db:smoke-test": "tsx ./scripts/db-smoke-test.ts",
    "start": "next start",
    "lint": "tsc --noEmit",
    "postbuild": "next-sitemap",
    "audit:dataset": "npm run pipeline:audit",
    "pipeline:audit": "tsx ./scripts/pipeline-audit.ts",
    "pipeline:batch-report": "tsx ./scripts/pipeline-batch-report.ts",
    "pipeline:load-batch": "tsx ./scripts/pipeline-load-batch.ts",
    "pipeline:ops-report": "tsx ./scripts/pipeline-ops-report.ts",
    "pipeline:plan-crawl": "tsx ./scripts/pipeline-plan-crawl.ts",
    "pipeline:run-cycle": "tsx ./scripts/pipeline-run-cycle.ts",
    "pipeline:run-crawl": "tsx ./scripts/pipeline-run-crawl.ts",
    "pipeline:publishability": "tsx ./scripts/generate-publishability-manifest.ts && node ./scripts/generate-launch-index-manifest.mjs",
    "test:pipeline": "tsx --test pipeline/*.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-dismissable-layer": "^1.1.11",
    "@radix-ui/react-popper": "^1.2.8",
    "@radix-ui/react-portal": "^1.1.10",
    "@radix-ui/react-presence": "^1.1.5",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "14.2.35",
    "next-sitemap": "^4.2.3",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.22",
    "@types/pg": "^8.15.6",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "eslint-import-resolver-typescript": "^4.4.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
